# Stock Scout — example environment file.
#
# Copy this to .env and fill in your own values. .env is gitignored and must
# NEVER be committed. Secrets live ONLY here (and in your host's env vars) —
# never in config.yml. Values are read by scout/config.py::load_env().

# ── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram chat id (from @userinfobot). The relay answers ONLY this
# chat and refuses to start until both this and the token are set.
TELEGRAM_OWNER_CHAT_ID=

# Anthropic API key from https://console.anthropic.com/ — pay-as-you-go, billed to
# this key. This is NOT a Claude.ai (Pro/Max) subscription; those include no API
# credits. The API has no free tier.
ANTHROPIC_API_KEY=

# ── Optional: database ──────────────────────────────────────────────────────

# Postgres connection string. If unset, Stock Scout uses a local JSON store under
# scout/_localdb/ (fine for local use; use Postgres for an always-on deploy).
# The legacy postgres:// scheme is normalized to postgresql:// automatically.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Optional: market data (read-only) ───────────────────────────────────────

# Alpaca read-only data API keys (https://alpaca.markets/). Used for GET-only
# price/company enrichment — there is no order code in this project. Leave blank
# to run on SEC EDGAR alone.
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=

# ── Optional: build stamp ───────────────────────────────────────────────────

# A friendly version label shown at startup. If unset, a build date / git SHA is
# used automatically.
# SCOUT_VERSION=
